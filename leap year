import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int num;
        Scanner sc=new Scanner(System.in);
        num=sc.nextInt();
        if (num % 4==0 && num % 100!=0 || num % 400==0)
        {
            System.out.println("Leap Year");
        }
        else
        {
            System.out.println("Not Leap Year");
        }
    }
}
